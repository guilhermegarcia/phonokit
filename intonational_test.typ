#import "lib.typ": *

// Basic example from the manual
You're a were#int("*L")wolf?#int("H%", line: false)

#v(2em)

// Boundary tone with line
She left#int("L+H*") already#int("L-L%")

#v(2em)

// Downstepped tone
He #int("!H*")said no#int("L-L%")

#v(2em)

// Multiple pitch accents, no lines on boundary tones
Did #int("H*")you see#int("L+H*") that#int("L-H%", line: false)

#v(2em)

// Custom height and lift
The rain#int("*L", height: 2em, lift: 0.6em) in Spain#int("H%", line: false)

#v(2em)

// All labels with stems
A#int("H*") B#int("L*") C#int("L+H*") D#int("!H*") E#int("L-L%")
